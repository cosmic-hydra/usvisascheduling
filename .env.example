# ─── Required credentials ────────────────────────────────────────────────────
USVISA_USERNAME=your@email.com
USVISA_PASSWORD=yourpassword

# Security question answers.
# The built-in keyword AI reads the actual question text and routes answers
# correctly even if the questions appear in a different order each login.
# Label each answer so the keyword matcher knows which question it belongs to:
#   Q1 = mother's maiden name answer
#   Q2 = birth city / childhood / pet / etc.
#   Q3 = third question answer
USVISA_Q1=answer1
USVISA_Q2=answer2
USVISA_Q3=answer3

# ─── AI (optional — a smarter cloud model if you have a key) ─────────────────
# Without this key the built-in rule-based AI handles everything automatically.
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Telegram notifications ───────────────────────────────────────────────────
# Create a bot via @BotFather, get your chat ID via @userinfobot.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# ─── IP rotation (for Cloudflare rate-limit bypass) ──────────────────────────
# tor       — rotate Tor circuit via NEWNYM  [recommended; pkg install tor]
# airplane  — toggle Android airplane mode  [requires root]
# wifi      — cycle WiFi adapter             [requires termux-api or root]
# none      — disable (fall back to timed back-off only)
IP_ROTATION_METHOD=tor

# ─── Monitoring & booking behaviour ──────────────────────────────────────────
# Minutes to wait between scan cycles (default: 15).
MONITOR_INTERVAL_MINUTES=15

# true  → Telegram fires only when a date earlier than the current best is found
# false → Telegram fires every cycle
NOTIFY_ONLY_ON_IMPROVEMENT=true

# ─── Posts to scan ───────────────────────────────────────────────────────────
# Leave blank to scan ALL OFC/consulate centres in the dropdown (recommended).
# USVISA_POSTS=chennai,delhi,bangalore,mumbai,hyderabad,kolkata

# ─── Cloudflare tuning ───────────────────────────────────────────────────────
# Seconds to wait before clicking the Turnstile checkbox (default: 8).
CF_CLICK_DELAY_SECONDS=8
# Minutes to wait if stuck in CF Waiting Room (default: 30).
MAX_WAIT_MINUTES=30

# ─── Calendar / booking ──────────────────────────────────────────────────────
# How many months ahead to scan per post (default: 12).
CALENDAR_MONTHS=12
# Text of the reschedule link on the dashboard (default: Reschedule Appointment).
# RESCHEDULE_LINK_TEXT=Reschedule Appointment

# ─── Chrome / display ────────────────────────────────────────────────────────
# On Termux this is auto-detected; override only if needed.
# CHROME_PATH=/data/data/com.termux/files/usr/bin/chromium
# TS_PROFILE_DIR=/data/data/com.termux/files/home/.usvisa_profile
