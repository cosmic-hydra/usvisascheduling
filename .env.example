# ─── Required credentials ────────────────────────────────────────────────────
USVISA_USERNAME=your@email.com
USVISA_PASSWORD=yourpassword

# Security question answers (order Q1→Q2→Q3 only matters as a fallback;
# the AI matcher reads the actual question text and routes answers correctly).
USVISA_Q1=answer1
USVISA_Q2=answer2
USVISA_Q3=answer3

# ─── AI-powered security question matching (recommended) ─────────────────────
# Get a key at https://console.anthropic.com/
# If unset, answers are filled in Q1→Q2→Q3 order (may be wrong if order changes).
ANTHROPIC_API_KEY=sk-ant-...

# ─── Telegram notifications ───────────────────────────────────────────────────
# Create a bot via @BotFather, then get your chat ID via @userinfobot.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# ─── Monitoring behaviour ─────────────────────────────────────────────────────
# How many minutes to wait between scan cycles (default: 15).
MONITOR_INTERVAL_MINUTES=15

# true  → only send Telegram when a date *earlier* than the current best is found
# false → send Telegram every cycle regardless
NOTIFY_ONLY_ON_IMPROVEMENT=true

# ─── Posts to scan ───────────────────────────────────────────────────────────
# Comma-separated OFC post labels/values to check.
# Leave commented out (or empty) to scan ALL posts in the dropdown.
# USVISA_POSTS=chennai,delhi,bangalore,mumbai,hyderabad,kolkata

# ─── Auto-booking (optional) ─────────────────────────────────────────────────
AUTO_BOOK=false
# CSS selectors required when AUTO_BOOK=true:
# BOOK_DATE_SELECTOR=
# BOOK_TIME_SELECTOR=
# BOOK_SUBMIT_SELECTOR=

# ─── Advanced tuning ─────────────────────────────────────────────────────────
# Seconds to pause before clicking the Cloudflare Turnstile checkbox (default: 8).
CF_CLICK_DELAY_SECONDS=8
# Minutes to wait if stuck in CF Waiting Room (default: 30).
MAX_WAIT_MINUTES=30
# How many calendar months to scan per post (default: 12).
CALENDAR_MONTHS=12
# Text of the reschedule link to click (default: Reschedule Appointment).
# RESCHEDULE_LINK_TEXT=Reschedule Appointment

# ─── Chrome / display ────────────────────────────────────────────────────────
# CHROME_PATH=/usr/bin/google-chrome
# TS_PROFILE_DIR=/tmp/usvisa_profile
